# --- DataMETL app metadata DB (Postgres run by docker-compose) ---
APP_DB_USER=datametl
APP_DB_PASSWORD=datametl
APP_DB_NAME=datametl
APP_DB_HOST=app-postgres
APP_DB_PORT=5432

# Backend reads this composed URL
DATABASE_URL=postgresql+psycopg://datametl:datametl@app-postgres:5432/datametl

# --- Redis (arq queue) ---
REDIS_URL=redis://redis:6379/0

# --- Credential vault ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_FERNET_KEY

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Sample DBs (optional, only used with --profile samples) ---
SAMPLE_SOURCE_PASSWORD=samplesource
SAMPLE_DEST_PASSWORD=sampledest
