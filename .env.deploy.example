# DataMETL deployment env (the install.sh script generates a .env from this and
# automatically fills ENCRYPTION_KEY with a freshly-minted Fernet key).

# --- Required ---
# Fernet key used to encrypt user-supplied DB credentials at rest. Generate with:
#   openssl rand -base64 32 | tr '+/' '-_'
# install.sh does this for you on first run.
ENCRYPTION_KEY=

# --- Optional, with sensible defaults ---
# The release tag (or "latest") to pull from ghcr.io/sbcsp/*
DATAMETL_VERSION=latest

# Host port to expose the UI on. The backend / DB / Redis are NOT exposed by default —
# the frontend proxies API requests internally. 3005 avoids the most common collisions
# (3000 is the default for many dev tools). Change freely; only this port is exposed.
FRONTEND_PORT=3005

# Core app config (lives in .env, but user-facing and can be overridden at runtime with env vars).
CORS_ORIGINS=http://localhost:3005

# App's own metadata DB credentials (lives inside docker-compose; not user-facing).
APP_DB_USER=datametl
APP_DB_PASSWORD=datametl
APP_DB_NAME=datametl

# Logging
LOG_LEVEL=INFO
